rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownerEmail() {
      return signedIn() && request.auth.token.email in ['jhoaoollerena@gmail.com'];
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userExists(uid) {
      return exists(userPath(uid));
    }

    function role() {
      return ownerEmail()
        ? 'admin'
        : (signedIn() && userExists(request.auth.uid)
            ? get(userPath(request.auth.uid)).data.role
            : 'customer');
    }

    function admin() {
      return signedIn() && role() == 'admin';
    }

    function seller() {
      return signedIn() && role() == 'seller';
    }

    match /users/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && (
          request.resource.data.role == 'customer'
          || (request.resource.data.role == 'admin' && ownerEmail())
        );

      allow read: if signedIn() && (request.auth.uid == userId || admin());

      allow update: if signedIn() && (
        admin()
        || (
          request.auth.uid == userId
          && request.resource.data.role == resource.data.role
        )
      );

      allow delete: if admin();
    }

    match /categories/{categoryId} {
      allow read: if signedIn();
      allow create, update, delete: if admin();
    }

    match /products/{productId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && (seller() || admin())
        && request.resource.data.sellerId == request.auth.uid;

      allow update: if signedIn() && (
        admin()
        || (
          seller()
          && resource.data.sellerId == request.auth.uid
          && request.resource.data.sellerId == resource.data.sellerId
          && request.resource.data.approvalStatus == 'pending'
        )
      );

      allow delete: if signedIn() && (
        admin()
        || (seller() && resource.data.sellerId == request.auth.uid)
      );
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read: if signedIn() && (
        admin()
        || resource.data.userId == request.auth.uid
        || request.auth.uid in resource.data.sellerIds
      );

      allow update: if admin();
      allow delete: if admin();
    }

    match /roleRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;

      allow read: if signedIn() && (
        admin()
        || resource.data.userId == request.auth.uid
      );

      allow update, delete: if admin();
    }

    match /notifications/{notificationId} {
      allow read, create, update, delete: if signedIn()
        && (admin() || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid);
    }
  }
}
